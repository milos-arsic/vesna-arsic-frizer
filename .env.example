# Database (Neon PostgreSQL - free tier)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth.js (local dev — on Vercel use AUTH_URL=https://vesna.hair)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3002

# Google OAuth (Google Cloud Console - free)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin email(s) - comma separated
ADMIN_EMAILS=vesna@example.com

# Resend (free tier: 3,000 emails/month) — verify domain at resend.com/domains
RESEND_API_KEY=
EMAIL_FROM="Vesna Arsić <termini@vesna.hair>"

# Shop info
SHOP_NAME="Vesna Arsić – Frizer"
SHOP_PHONE=0641234567
SHOP_ADDRESS="Žarka Jelića 5a, Dobanovci 11272"
